{
  "name": "@doxynix/siem-server",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "with-doppler": "bun scripts/doppler.ts",
    "dev": "bun with-doppler \"concurrently -n api,types 'bun run --watch src/index.ts' 'tsc --watch'\"",
    "db:generate": "bun with-doppler drizzle-kit generate",
    "db:push": "bun with-doppler drizzle-kit push",
    "db:studio": "bun with-doppler drizzle-kit studio",
    "db:migrate": "bun with-doppler drizzle-kit migrate"
  },
  "dependencies": {
    "@axiomhq/js": "^1.8.0",
    "@doxynix/siem-shared": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
